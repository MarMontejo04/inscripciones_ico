doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Inscripción de Materias
    style.
      body { font-family: Arial, sans-serif; max-width: 900px; margin: 40px auto; padding: 0 20px; }
      table { width: 100%; border-collapse: collapse; margin-top: 20px; }
      th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
      th { background-color: #f4f4f4; }
      input, select { padding: 8px; margin: 5px 0; border: 1px solid #ddd; border-radius: 4px; }
      button { padding: 10px 20px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; }
      .error { color: red; padding: 10px; background: #ffe0e0; border-radius: 4px; margin: 10px 0; }
      .exito { color: green; padding: 10px; background: #e0ffe0; border-radius: 4px; margin: 10px 0; }

  body
    h1 Inscripción de Materias

    if error
      p.error= error
    if exito
      p.exito= exito

    form(action="/inscripciones" method="POST")
      h3 Datos del alumno
      label Número de cuenta:
      br
      input(type="number" name="num_cuenta" placeholder="Ej: 123456789" required)
      br
      label Semestre en curso:
      br
      input(type="text" name="semestre_curso" placeholder="Ej: 2025-2" required)

      h3 Clases disponibles
      table
        thead
          tr
            th Seleccionar
            th Materia
            th Profesor
            th Grupo
            th Créditos
            th Día
            th Horario
            th Salón
        tbody
          each clase in clases
            tr
              td
                input(type="radio" name="id_clase" value=clase.id_clase required)
              td= clase.asignatura.nombre_asignatura
              td= clase.profesor.nombre + ' ' + clase.profesor.ap_paterno
              td= clase.grupoClase.num_grupo
              td= clase.asignatura.creditos
              td= clase.dia_semana
              td= clase.hora_inicio + ' - ' + clase.hora_final
              td= clase.salon

      br
      button(type="submit") Inscribirse