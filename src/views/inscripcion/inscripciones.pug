doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")

    title Inscripción de Materias

    link(rel='stylesheet', href='/bootstrap/css/bootstrap.min.css')
    link(rel='stylesheet', href='/css/inscripciones.css')

  body

    .container.main-container

      .card-custom

        .d-flex.justify-content-between.align-items-center.mb-4

          div
            h1.mb-1 Inscripción de Materias
            p.text-muted Sistema Escolar · FES Aragón

          img(
            src='/img/logo.png'
            alt='UNAM'
            width='90'
            class='img-fluid'
          )

        if error
          .error= error

        if exito
          .success= exito

        //- Información del alumno
        .student-info

          h4.mb-3 Información del Alumno

          .row

            .col-md-6
              p
                strong Nombre:
                |  #{alumno.nombre} #{alumno.ap_paterno} #{alumno.ap_materno}

            .col-md-6
              p
                strong Número de cuenta:
                |  #{alumno.num_cuenta}

            .col-md-6
              p
                strong Correo:
                |  #{alumno.correo}

            .col-md-6
              p
                strong Semestre actual:
                |  #{alumno.semestre}

        //- Panel de tres columnas
        
        form(action="/inicio" method="POST")

          input(type="hidden" name="id_alumno" value=alumno.id_alumno)
          input(type="hidden" name="clases_inscritas" id="clases_inscritas" value="")

          .inscripcion-panel

            //- ── Columna izquierda: materias disponibles ──
            .panel-col

              .panel-header
                h5 Materias disponibles
                small(id="count-disponibles") Cargando...

              .panel-list#lista-disponibles

                if clasesAgrupadas

                  each clasesSemestre, semestre in clasesAgrupadas

                    if clasesSemestre.length > 0

                      if semestre === 'optativas'

                        p.px-2.pt-3.mb-1(
                          style="font-size:11px;font-weight:700;color:#b45309;text-transform:uppercase;letter-spacing:.05em;"
                        ) Optativas

                      else

                        p.px-2.pt-3.mb-1(
                          style="font-size:11px;font-weight:700;color:#0a58ca;text-transform:uppercase;letter-spacing:.05em;"
                        ) #{semestre}° Semestre

                      each clase in clasesSemestre

                        .materia-item(
                          data-id=clase.id_clase
                          data-asignatura=clase.clave_materia
                          data-nombre=clase.asignatura.nombre_asignatura
                          data-creditos=clase.asignatura.creditos
                          data-semestre=semestre
                          data-optativa=clase.asignatura.optativa
                          onclick="seleccionarDisponible(this)"
                        )
                          .materia-nombre= clase.asignatura.nombre_asignatura
                          .materia-meta
                            | Grupo #{clase.grupoClase.num_grupo}
                            |  · #{clase.dia_semana}
                            |  #{clase.hora_inicio} - #{clase.hora_final}
                            |  · #{clase.profesor.nombre} #{clase.profesor.ap_paterno}
                            |  ·&nbsp;
                            if clase.asignatura.optativa
                              span.badge-optativa Optativa
                            else
                              span.badge-obligatoria Obligatoria

                else

                  .empty-hint
                    | No hay clases disponibles actualmente.

            //- ── Columna central: botones de acción ──
            .divider-col

              p.hint Selecciona y usa los botones

              button.btn-inscribir#btn-inscribir(
                type="button"
                disabled
                onclick="inscribirMateria()"
              )
                | ▶ Inscribir

              button.btn-baja#btn-baja(
                type="button"
                disabled
                onclick="darBaja()"
              )
                | ◀ Dar de baja

            //- ── Columna derecha: materias inscritas ──
            .panel-col

              .panel-header
                h5 Materias inscritas
                small(id="count-inscritas") 0 materias · 0 créditos

              .panel-list#lista-inscritas

                .empty-hint#hint-vacio
                  | Sin materias inscritas aún.

          //- Barra inferior
          .bottom-bar

            .credits-summary
              | Total de créditos: &nbsp;
              strong#total-creditos 0

            button.btn-submit#btn-submit(
              type="submit"
              disabled
              onclick="prepararEnvio()"
            )
              | ✔ Aceptar materias inscritas

    script(src='/js/inscripciones.js')