doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")

    title Inscripción de Materias

    link(rel='stylesheet', href='/bootstrap/css/bootstrap.min.css')

    style.
      body{
        background:#f4f6f9;
        font-family: Arial, sans-serif;
      }

      .main-container{
        max-width:1200px;
        margin:40px auto;
      }

      .card-custom{
        background:white;
        border-radius:12px;
        padding:30px;
        box-shadow:0 4px 18px rgba(0,0,0,.08);
      }

      .table thead{
        background:#0d6efd;
        color:white;
      }

      .student-info{
        background:#eef4ff;
        border-left:5px solid #0d6efd;
        padding:18px;
        border-radius:8px;
        margin-bottom:25px;
      }

      .btn-submit{
        padding:12px 24px;
        border:none;
        border-radius:8px;
        background:#0d6efd;
        color:white;
        font-weight:bold;
        transition:.2s;
      }

      .btn-submit:hover{
        background:#0b5ed7;
      }

      .error{
        background:#ffe5e5;
        color:#b00020;
        padding:12px;
        border-radius:8px;
        margin-bottom:15px;
      }

      .success{
        background:#e5ffe8;
        color:#006b21;
        padding:12px;
        border-radius:8px;
        margin-bottom:15px;
      }

      .badge-optativa{
        background:#ffc107;
        color:#000;
        padding:6px 10px;
        border-radius:20px;
        font-size:.8rem;
        font-weight:bold;
      }

      .badge-obligatoria{
        background:#0d6efd;
        color:white;
        padding:6px 10px;
        border-radius:20px;
        font-size:.8rem;
        font-weight:bold;
      }

      .semester-badge{
        background:#e9ecef;
        padding:5px 10px;
        border-radius:20px;
        font-weight:bold;
      }

  body

    .container.main-container

      .card-custom

        .d-flex.justify-content-between.align-items-center.mb-4

          div
            h1.mb-1 Inscripción de Materias
            p.text-muted Sistema Escolar · FES Aragón

          img(
            src='/img/logo.png'
            alt='UNAM'
            width='90'
            class='img-fluid'
          )

        if error
          .error= error

        if exito
          .success= exito

  
        .student-info

          h4.mb-3 Información del Alumno

          .row

            .col-md-6
              p
                strong Nombre:
                |  #{alumno.nombre} #{alumno.ap_paterno} #{alumno.ap_materno}

            .col-md-6
              p
                strong Número de cuenta:
                |  #{alumno.num_cuenta}

            .col-md-6
              p
                strong Correo:
                |  #{alumno.correo}

            .col-md-6
              p
                strong Semestre actual:
                |  #{alumno.semestre}

   
        form(action="/inscripciones" method="POST")

          input(
            type="hidden"
            name="id_alumno"
            value=alumno.id_alumno
          )

          

          h4.mb-3 Clases Disponibles

          if clasesAgrupadas

            each clasesSemestre, semestre in clasesAgrupadas

              if clasesSemestre.length > 0

                if semestre === 'optativas'

                  .mt-5.mb-3
                    h3.text-warning.fw-bold
                      | Materias Optativas

                else

                  .mt-5.mb-3
                    h3.text-primary.fw-bold 
                      | #{semestre}° Semestre

                //- ====================================
                //- TABLA
                //- ====================================

                .table-responsive

                  table.table.table-hover.table-bordered.align-middle

                    thead
                      tr
                        th Seleccionar
                        th Materia
                        th Tipo
                        th Profesor
                        th Grupo
                        th Créditos
                        th Día
                        th Horario
                        th Salón

                    tbody

                      each clase in clasesSemestre

                        tr

                          //- RADIO
                          td.text-center
                            input(
                              type="radio"
                              name="id_clase"
                              value=clase.id_clase
                              required
                            )

                          //- MATERIA
                          td.fw-semibold
                            = clase.asignatura.nombre_asignatura

                          //- TIPO
                          td.text-center

                            if (clase.asignatura.optativa)

                              span.badge-optativa
                                | Optativa

                            else

                              span.badge-obligatoria
                                | Obligatoria

                          //- PROFESOR
                          td
                            | #{clase.profesor.nombre}
                            |  #{clase.profesor.ap_paterno}

                          //- GRUPO
                          td.text-center
                            = clase.grupoClase.num_grupo

                          //- CREDITOS
                          td.text-center
                            = clase.asignatura.creditos

                          //- DIA
                          td
                            = clase.dia_semana

                          //- HORARIO
                          td
                            | #{clase.hora_inicio}
                            |  -
                            |  #{clase.hora_final}

                          //- SALON
                          td.text-center
                            = clase.salon

          else


            .alert.alert-warning
              | No hay clases disponibles actualmente.

          .mt-4.d-flex.justify-content-end

            button.btn-submit(type="submit")
              | Inscribirse